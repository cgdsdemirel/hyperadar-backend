# ── Required ─────────────────────────────────────────────────────────────────
# Supabase: use Transaction Mode pooler URL (port 6543), NOT the direct connection URL
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxx

ADMIN_EMAIL=admin@hyperadar.com
ADMIN_PASSWORD=

# ── Optional — disables related feature if missing ────────────────────────────
YOUTUBE_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
PRODUCT_HUNT_API_KEY=
APPLE_SHARED_SECRET=

# Stringify the service account JSON: node -e "console.log(JSON.stringify(require('./service-account.json')))"
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_PLAY_PACKAGE_NAME=com.hyperadar.mobile

# RevenueCat secret key — get from RC Dashboard → Project → API Keys → Secret keys (sk_...)
REVENUECAT_SECRET_KEY=sk_xxxxxxxxxxxxxxxx

# Sentry — get from sentry.io → Project → Settings → Client Keys → DSN
SENTRY_DSN=https://xxxxxxxx@oxxxxxxx.ingest.sentry.io/xxxxxxxx

# Comma-separated list of allowed CORS origins (your Vercel admin panel URL)
ALLOWED_ORIGINS=https://hyperadar-admin.vercel.app

PORT=3000
NODE_ENV=production
